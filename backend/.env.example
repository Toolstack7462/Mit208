# PhishGuard backend configuration
# ---------------------------------
# PostgreSQL (default for professor demo). Create the DB first:
#   createdb phishguard_db     (or use the database/schema.sql script)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/phishguard_db

# Zero-install fallback for a quick demo (no PostgreSQL needed):
# DATABASE_URL=sqlite:///./phishguard.db

# JWT signing secret - CHANGE THIS in any real deployment
SECRET_KEY=dev-only-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - the Vite dev server origin
FRONTEND_ORIGIN=http://localhost:5173
